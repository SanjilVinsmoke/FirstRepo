# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development

# Max upload size in bytes (default 10 MB for free tier)
MAX_UPLOAD_BYTES=10485760

# Where to store uploads/outputs locally (relative to project root)
LOCAL_UPLOAD_DIR=./uploads

# ─── Storage: set STORAGE_PROVIDER=s3 to use S3-compatible storage ─────
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3

# S3 / R2 / MinIO credentials (only needed when STORAGE_PROVIDER=s3)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
# For non-AWS S3-compatible services (R2, MinIO, etc.):
# S3_ENDPOINT=https://your-endpoint.example.com

# ─── Rate Limiting ───────────────────────────────────────────────────────
# Requests per window per IP
RATE_LIMIT_MAX=10
# Window in seconds
RATE_LIMIT_WINDOW=60

# ─── Stripe (placeholder – not yet implemented) ──────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
